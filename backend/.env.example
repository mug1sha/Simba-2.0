# Simba 2.0 Backend Configuration

# Runtime
APP_ENV=development

# Security
SECRET_KEY=YOUR_SUPER_SECRET_KEY_REPLACE_IN_PROD
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# Database
DATABASE_URL=sqlite:///./simba.db

# Frontend Integration
FRONTEND_URL=http://127.0.0.1:8080

# CORS
CORS_ORIGINS=http://127.0.0.1:8080,http://localhost:8080,http://localhost:5173
GOOGLE_CLIENT_ID=your-google-oauth-web-client-id

# Email Service (writes to dev mailbox unless SMTP is configured)
DEV_MAILBOX_PATH=dev_mailbox.log
EMAIL_FROM=no-reply@example.com
# SMTP_HOST=smtp-relay.brevo.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-login
# SMTP_PASSWORD=your-smtp-key
# SMTP_USE_TLS=true
# SMTP_USE_SSL=false

# AI Support
# Get this from Groq Console and keep it server-side only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
